# =============================================================================
# MuckRock OAuth Authentication
# =============================================================================
MUCKROCK_CLIENT_ID=your-muckrock-client-id
MUCKROCK_CLIENT_SECRET=your-muckrock-client-secret
SESSION_SECRET=generate-with-python3-c-import-secrets-print-secrets-token_hex-32
OAUTH_REDIRECT_BASE=http://localhost:5173  # Public URL the browser sees (needed behind proxy)

# =============================================================================
# AI / LLM APIs
# =============================================================================
OPENROUTER_API_KEY=your-openrouter-api-key
LLM_MODEL=google/gemini-2.5-flash-lite

# =============================================================================
# Third-party APIs
# =============================================================================
FIRECRAWL_API_KEY=your-firecrawl-api-key
APIFY_API_TOKEN=your-apify-api-token
RESEND_API_KEY=your-resend-api-key

# =============================================================================
# Supabase (required for v2 Edge Functions + migration script)
# =============================================================================
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# AWS Configuration
# =============================================================================
AWS_API_BASE_URL=https://your-api-gateway.execute-api.region.amazonaws.com/dev
AWS_DEFAULT_REGION=eu-central-1
INTERNAL_SERVICE_KEY=your-internal-service-key

# DynamoDB (v1 → v2 cutover script, scripts/migrate/main.ts)
AWS_ACCESS_KEY_ID=your-read-only-iam-access-key
AWS_SECRET_ACCESS_KEY=your-read-only-iam-secret-key
DYNAMODB_TABLE=scraping-jobs
DYNAMODB_UNITS_TABLE=information-units

# EventBridge Scheduler — required for direct scout management (ScheduleService)
SCRAPER_LAMBDA_ARN=arn:aws:lambda:eu-central-1:123456789012:function:scraper-lambda
EVENTBRIDGE_ROLE_ARN=arn:aws:iam::123456789012:role/eventbridge-scheduler-role

# =============================================================================
# Frontend Environment Variables
# =============================================================================
PUBLIC_MAPTILER_API_KEY=your-maptiler-api-key
PUBLIC_SELF_HOST_LOGIN_NOTE=

# =============================================================================
# Optional Settings
# =============================================================================
ENVIRONMENT=development
DEFAULT_USER_CREDITS=100
DEFAULT_USER_TIMEZONE=UTC
DEBUG=True

# Email allowlist — comma-separated emails and/or @domain patterns (empty = allow all)
EMAIL_ALLOWLIST=

# =============================================================================
# Stripe — OSS License Key System
# =============================================================================
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
STRIPE_ANNUAL_PRICE_ID=price_your-annual-price-id
